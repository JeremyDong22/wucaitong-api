/* v1.0 - 物采通小程序全局样式 */
page {
  background: #f5f5f5;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.container {
  padding: 24rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-blue { background: #e6f4ff; color: #1677ff; }
.tag-green { background: #f6ffed; color: #52c41a; }
.tag-orange { background: #fff7e6; color: #fa8c16; }
.tag-red { background: #fff2f0; color: #ff4d4f; }
.tag-gray { background: #f0f0f0; color: #999; }

/* 主按钮 */
.btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
}

/* 次按钮 */
.btn-default {
  background: #fff;
  color: #333;
  border: 2rpx solid #d9d9d9;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}
