/* v1.0 - 公告列表样式 */
.loading-tip, .empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.announcement-card {
  position: relative;
}

.ann-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ann-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}

.ann-meta {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.ann-arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #ccc;
  font-size: 36rpx;
}
