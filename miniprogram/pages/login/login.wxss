/* v1.0 - 登录页样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.logo-area {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-title {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
}

.logo-sub {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 86%;
}

.form-item {
  margin-bottom: 36rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.sms-btn {
  width: 220rpx;
  height: 88rpx;
  background: #e6f4ff;
  color: #1677ff;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  flex-shrink: 0;
  line-height: 88rpx;
}

.sms-btn.disabled {
  color: #999;
  background: #f5f5f5;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: #1677ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  border: none;
}

.divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
  color: #ccc;
  font-size: 26rpx;
}

.divider::before, .divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
  margin: 0 20rpx;
}

.btn-wx {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 16rpx;
  border: none;
}
