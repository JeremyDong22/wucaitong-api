/* v1.0 - 订单列表样式 */
.empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 26rpx;
  color: #666;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.order-amount {
  font-size: 30rpx;
  color: #1677ff;
  font-weight: bold;
  text-align: right;
}
