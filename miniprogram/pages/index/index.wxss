/* v1.0 - 首页样式 */
.header-card {
  background: linear-gradient(135deg, #1677ff, #0958d9);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.welcome {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
}

.role-tag {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
}

.logout {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.menu-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.menu-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
